# Database Configuration
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database?schema=schema_name
DATABASE_URL="postgresql://admin:admin123@localhost:5432/bancoperu?schema=public"

# JWT Configuration
# Secret key used to sign JWT tokens. Must be a secure, random string in production
JWT_SECRET="change-this-to-a-secure-random-string-in-production"
# Token expiration time (e.g., 24h, 7d)
JWT_EXPIRES_IN="24h"
# Secret key for refresh tokens
REFRESH_TOKEN_SECRET="change-this-to-a-secure-random-string-for-refresh-tokens"
# Refresh token expiration time
REFRESH_TOKEN_EXPIRES_IN="7d"
# Number of bcrypt rounds for password hashing (higher = more secure but slower)
BCRYPT_ROUNDS=10

# Application Configuration
# Port where the backend API will run
PORT=3000
# Environment: development, production, or staging
NODE_ENV="development"
# API prefix for all routes (e.g., /api)
API_PREFIX="/api"

# CORS Configuration
# Comma-separated list of allowed origins for frontend requests
CORS_ORIGIN="http://localhost:3001,http://localhost:3000"
# Allow credentials (cookies, authorization headers) in cross-origin requests
CORS_CREDENTIALS="true"

# Logging Configuration
# Log level: error, warn, info, debug, verbose
LOG_LEVEL="debug"

# Redis Configuration (optional - for caching/sessions)
# Redis host address
REDIS_HOST="localhost"
# Redis port
REDIS_PORT=6379
# Redis password (empty if no authentication required)
REDIS_PASSWORD=""
# Redis database number (0-15)
REDIS_DB=0
