# Variables de entorno específicas para Railway
# Estas deben configurarse en Railway Dashboard -> Settings -> Variables

# Prisma Engine Configuration
PRISMA_CLI_BINARY_TARGETS=native,linux-musl,linux-musl-openssl-3.0.x
PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1

# OpenSSL Configuration
OPENSSL_CONF=/dev/null
